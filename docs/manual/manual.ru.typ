= Графика

В Forgotten catacombs используется символьная графика, использующая несколько расширенную ASCII-таблицу символов:

#grid(
    columns: 2,
    column-gutter: 1em,
    [
        - #symbol("@") - персонаж игрока или иной человекоподобный NPC;
        - #symbol("a-Y") - обозначают противников.
        - #symbol("~") - вода или силовое поле;
        - #symbol("·") - земля или пол;
        - #symbol("#") - скальная порода;
        - #symbol("│┐┌─┘└├┤┬┴┼") - стены палатки или внутреннего помещения;
        - #symbol("▒") - бетонная стена;
        - #symbol("<") - лестница наверх;
        - #symbol(">") - лестница вниз;
        - #symbol("_") - телепорт;
        - #symbol("^") - ловушка;
        - #symbol("‘") - открытая дверь;
        - #symbol("+") - закрытая дверь;
        - #symbol("±") - запертая дверь;
    ],
    [
        - #symbol("=") - куча вещей или открытый контейнер;
        - #symbol("≠") - запертый контейнер;
        - #symbol("%") - еда;
        - #symbol("¿") - пузырек с зельем;
        - #symbol("¡") - факел или фонарь;
        - #symbol("/") - оружие ближнего боя;
        - #symbol("\\") - неопознанное оружие ближнего боя;
        - #symbol("}") - оружие дальнего боя;
        - #symbol("{") - неопознанное оружие дальнего боя;
        - #symbol(";") - снаряды для оружия дальнего боя или метательное оружие;
        - #symbol("]") - броня;
        - #symbol("[") - неопознанная броня;
        - #symbol("&") - устройство или оборудование;
    ],
)

